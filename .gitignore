# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel
CLAUDE.md
AGENTS.md
# typescript
*.tsbuildinfo
next-env.d.ts

# stray generated images (not part of project)
/public/hf_*.webp
# raw source image dumps at public root (clean copies live in /public/gallery and /public/figma)
/public/*.jpg
/public/*.webp
/public/hf_*.webp
/public/Selmir Logo*
/public/Frame*.png
